/**
 * Cloudflare Workers config — deploys this repo as a Workers Static Assets
 * project from `./dist/`, with a Worker at src/worker.js that handles the
 * `/api/order` endpoint and falls through to static assets for everything
 * else.
 *
 * Default routing: with `main` set, Cloudflare serves matching assets
 * directly (no Worker invocation, no cost) and only invokes the Worker
 * for paths that don't match an asset — so `/api/order` hits the Worker
 * while `/index.html`, `/assets/*`, etc. are served straight from the
 * edge. The Worker can call `env.ASSETS.fetch(request)` for fall-through.
 *
 * vars vs. secrets:
 *   - Plaintext `vars` defined here are the canonical truth. Each
 *     `wrangler deploy` syncs the dashboard to whatever's in this file —
 *     anything dashboard-only gets wiped. Put non-sensitive config here.
 *   - Encrypted secrets (set with `wrangler secret put` or via the
 *     dashboard "Add" → "Secret") are stored separately and survive
 *     deploys. Use these for credentials / API keys.
 *
 * Secrets to keep in dashboard (encrypted, do NOT add here):
 *   RESEND_API_KEY     — required for /api/order to work
 *
 * Optional plaintext overrides (defaults are baked into worker.js):
 *   ORDER_TO_EMAIL     — defaults to tsghsunlee@gmail.com
 *   ORDER_FROM_EMAIL   — defaults to onboarding@resend.dev; switch to
 *                        noreply@jinhuasoap.com once the domain is
 *                        verified in Resend.
 *
 * KV bindings:
 *   ORDER_FALLBACK     — namespace gf-order-fallback. Worker writes
 *                        every order payload here before calling Resend
 *                        (30-day TTL). Successful sends delete the entry;
 *                        failed sends keep it for manual recovery via
 *                        Cloudflare dashboard. See README §0.7 SOP 3.
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jinhuasoap",
  "main": "src/worker.js",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "ECPAY_MERCHANT_ID": "3498678"
  },
  "kv_namespaces": [
    {
      "binding": "ORDER_FALLBACK",
      "id": "6e3ab3998c8e426a967b5fb2b05f6779"
    }
  ]
}
